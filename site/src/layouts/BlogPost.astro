---
import type { CollectionEntry } from 'astro:content';
import type { MarkdownHeading } from 'astro';
import ArticleHeader from '../components/ArticleHeader.astro';
import TopicQueue from '../components/TopicQueue.astro';
import Page from './Page.astro';
import { BASE, REPO_URL, SITE_TITLE, TOPICS_URL } from '../consts';

type Props = CollectionEntry<'blog'>['data'] & { headings?: MarkdownHeading[]; readingTime?: number };

const {
	title,
	description,
	date,
	tags = [],
	summary,
	issue,
	requestedBy,
	writer,
	reviewer,
	headings = [],
	readingTime,
} = Astro.props;
---

<Page title={`${SITE_TITLE} — ${title}`} description={description}>
	<article>
		<div class="prose" data-pagefind-body>
			<ArticleHeader {title} {date} {tags} {issue} {requestedBy} {writer} {reviewer} {readingTime} />
			{
				summary && (
					<aside class="tldr">
						<span class="label">TL;DR</span>
						<p>{summary}</p>
					</aside>
				)
			}
			{
				headings.length > 1 && (
					<nav class="toc" aria-label="Índice del artículo">
						<span class="label">En este artículo</span>
						<ol>
							{headings.map((h) => (
								<li>
									<a href={`#${h.slug}`}>{h.text}</a>
								</li>
							))}
						</ol>
					</nav>
				)
			}
			<slot />
		</div>
		<aside class="continue">
			<p class="command term-command">continuar</p>
			<h2>¿Has encontrado un error?</h2>
			<p>
				Este artículo se genera automáticamente. Comenta la corrección en la issue original
				para mantener la discusión junto al tema.
			</p>
			<div class="continue-links">
				{issue && <a href={`${REPO_URL}/issues/${issue}`} target="_blank">comentar corrección →</a>}
				<a href={TOPICS_URL} target="_blank">ver y votar próximos temas →</a>
				<a href={`${REPO_URL}/issues/new/choose`} target="_blank">proponer tema →</a>
				<a href={`${BASE}/articles/`}>volver a artículos →</a>
			</div>
		</aside>
		<TopicQueue limit={3} compact />
	</article>
</Page>

<style>
	/* The article column is narrower than the 880px default for readability. */
	:global(main) {
		width: 820px;
	}
	.prose {
		color: rgb(var(--gray-dark));
	}
	.tldr {
		margin: 0 0 1.5em 0;
		padding: 1em 1.25em;
		border: 1px solid rgb(var(--gray-light));
		border-left: 3px solid var(--accent);
		border-radius: 6px;
		background: linear-gradient(90deg, rgba(255, 180, 84, 0.045), var(--bg-raise) 36%);
		box-shadow: var(--panel-shadow);
	}
	.tldr .label {
		display: block;
		margin-bottom: 0.4em;
		font-family: var(--font-mono);
		font-size: 0.75em;
		font-weight: 700;
		letter-spacing: 0.08em;
		color: var(--accent);
	}
	.tldr p {
		margin: 0;
	}
	.toc {
		margin: 0 0 2.5em 0;
		padding: 1em 1.25em;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 6px;
		font-family: var(--font-mono);
		font-size: 0.85em;
		background: rgba(17, 21, 28, 0.5);
	}
	.toc .label {
		display: block;
		margin-bottom: 0.5em;
		font-size: 0.85em;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: rgb(var(--gray));
	}
	.toc ol {
		margin: 0;
		padding-left: 1.4em;
	}
	.toc li {
		margin: 0.25em 0;
	}
	.toc a {
		color: rgb(var(--gray-dark));
	}
	.toc a:hover {
		color: var(--accent);
		text-decoration: none;
	}
	.continue {
		margin-top: 3em;
		padding: 1.25em 1.5em;
		border: 1px solid rgb(var(--gray-light));
		border-left: 3px solid var(--accent);
		border-radius: 6px;
		background: var(--bg-raise);
	}
	.continue .command {
		margin: 0 0 0.6em;
		font-size: 0.8em;
	}
	.continue h2 {
		margin: 0 0 0.35em;
		font-family: var(--font-sans);
		font-size: 1.15em;
	}
	.continue p {
		margin-bottom: 0.8em;
	}
	.continue-links {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5em 1.4em;
		font-family: var(--font-mono);
		font-size: 0.82em;
	}
	@media (max-width: 720px) {
		.toc {
			margin-bottom: 2em;
		}
	}
</style>
