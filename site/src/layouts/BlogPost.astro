---
import type { CollectionEntry } from 'astro:content';
import type { MarkdownHeading } from 'astro';
import TopicQueue from '../components/TopicQueue.astro';
import Page from './Page.astro';
import { BASE, REPO_URL, TOPICS_URL } from '../consts';

type Props = CollectionEntry<'blog'>['data'] & { headings?: MarkdownHeading[] };

const {
	title,
	description,
	pubDate,
	tags = [],
	summary,
	issue,
	requestedBy,
	model,
	headings = [],
} = Astro.props;
---

<Page title={title} description={description}>
	<article>
		<div class="prose" data-pagefind-body>
			<div class="title">
				<h1>{title}</h1>
				<div class="meta">
					<span class="fence">---</span>
					<div>
						<span class="key">pubDate:</span>
						<span class="value">{pubDate.toISOString().slice(0, 10)}</span>
					</div>
					{
						tags.length > 0 && (
							<div>
								<span class="key">tags:</span>
								<span class="value">
									[{tags.map((tag, i) => (
										<><a href={`${BASE}/tags/${tag}/`}>{tag}</a>{i < tags.length - 1 ? ', ' : ''}</>
									))}]
								</span>
							</div>
						)
					}
					{
						issue && (
							<div>
								<span class="key">issue:</span>
								<a href={`${REPO_URL}/issues/${issue}`} target="_blank">#{issue}</a>
								{requestedBy && (
									<span class="value">
										(<a href={`https://github.com/${requestedBy}`} target="_blank">@{requestedBy}</a>)
									</span>
								)}
							</div>
						)
					}
					{
						model && (
							<div>
								<span class="key">model:</span>
								<span class="value">{model}</span>
							</div>
						)
					}
					<span class="fence">---</span>
				</div>
			</div>
			{
				summary && (
					<aside class="tldr">
						<span class="label">TL;DR</span>
						<p>{summary}</p>
					</aside>
				)
			}
			{
				headings.length > 1 && (
					<nav class="toc" aria-label="Índice del artículo">
						<span class="label">En este artículo</span>
						<ol>
							{headings.map((h) => (
								<li>
									<a href={`#${h.slug}`}>{h.text}</a>
								</li>
							))}
						</ol>
					</nav>
				)
			}
			<slot />
		</div>
		<aside class="continue">
			<p class="command">continuar</p>
			<h2>¿Has encontrado un error?</h2>
			<p>
				Este artículo se genera automáticamente. Comenta la corrección en la issue original
				para mantener la discusión junto al tema.
			</p>
			<div class="continue-links">
				{issue && <a href={`${REPO_URL}/issues/${issue}`} target="_blank">comentar corrección →</a>}
				<a href={TOPICS_URL} target="_blank">ver y votar próximos temas →</a>
				<a href={`${REPO_URL}/issues/new/choose`} target="_blank">proponer tema →</a>
				<a href={`${BASE}/articles/`}>volver a artículos →</a>
			</div>
		</aside>
		<TopicQueue limit={3} compact />
	</article>
</Page>

<style>
	/* The article column is narrower than the 880px default for readability. */
	:global(main) {
		width: 820px;
	}
	.prose {
		color: rgb(var(--gray-dark));
	}
	.title {
		margin-bottom: 1.5em;
		padding: 1.5em 0;
		border-bottom: 1px solid rgb(var(--gray-light));
	}
	.title h1 {
		margin: 0 0 0.8em 0;
		font-family: var(--font-sans);
		font-weight: 700;
		font-size: 2.1em;
		letter-spacing: -0.02em;
		line-height: 1.15;
	}
	/* Article metadata rendered as its own frontmatter */
	.meta {
		padding: 0.8em 1.25em;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 6px;
		background: var(--bg-raise);
		font-family: var(--font-mono);
		font-size: 0.8em;
		line-height: 1.9;
		overflow-x: auto;
	}
	.meta .fence,
	.meta .key {
		color: rgb(var(--gray));
	}
	.meta .fence {
		display: block;
	}
	.meta .value {
		color: rgb(var(--gray-dark));
	}
	.meta a {
		color: var(--accent);
		text-decoration: none;
	}
	.meta a:hover {
		text-decoration: underline;
		text-underline-offset: 3px;
	}
	.tldr {
		margin: 0 0 1.5em 0;
		padding: 1em 1.25em;
		border: 1px solid rgb(var(--gray-light));
		border-left: 3px solid var(--accent);
		border-radius: 6px;
		background: var(--bg-raise);
	}
	.tldr .label {
		display: block;
		margin-bottom: 0.4em;
		font-family: var(--font-mono);
		font-size: 0.75em;
		font-weight: 700;
		letter-spacing: 0.08em;
		color: var(--accent);
	}
	.tldr p {
		margin: 0;
	}
	.toc {
		margin: 0 0 2.5em 0;
		padding: 1em 1.25em;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 6px;
		font-family: var(--font-mono);
		font-size: 0.85em;
	}
	.toc .label {
		display: block;
		margin-bottom: 0.5em;
		font-size: 0.85em;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: rgb(var(--gray));
	}
	.toc ol {
		margin: 0;
		padding-left: 1.4em;
	}
	.toc li {
		margin: 0.25em 0;
	}
	.toc a {
		color: rgb(var(--gray-dark));
	}
	.toc a:hover {
		color: var(--accent);
		text-decoration: none;
	}
	.continue {
		margin-top: 3em;
		padding: 1.25em 1.5em;
		border: 1px solid rgb(var(--gray-light));
		border-left: 3px solid var(--accent);
		border-radius: 6px;
		background: var(--bg-raise);
	}
	.continue .command {
		margin: 0 0 0.6em;
		font-family: var(--font-mono);
		font-size: 0.8em;
		color: var(--accent);
	}
	.continue .command::before {
		content: '$ ';
		color: rgb(var(--gray));
	}
	.continue h2 {
		margin: 0 0 0.35em;
		font-family: var(--font-sans);
		font-size: 1.15em;
	}
	.continue p {
		margin-bottom: 0.8em;
	}
	.continue-links {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5em 1.4em;
		font-family: var(--font-mono);
		font-size: 0.82em;
	}
	@media (max-width: 720px) {
		.title {
			padding-top: 0.5em;
		}
		.title h1 {
			font-size: 1.85em;
		}
		.meta {
			padding: 0.7em 1em;
			line-height: 1.7;
		}
		.toc {
			margin-bottom: 2em;
		}
	}
</style>
