---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import type { MarkdownHeading } from 'astro';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { REPO_URL } from '../consts';

type Props = CollectionEntry<'blog'>['data'] & { headings?: MarkdownHeading[] };

const {
	title,
	description,
	pubDate,
	updatedDate,
	heroImage,
	tags = [],
	summary,
	issue,
	requestedBy,
	headings = [],
} = Astro.props;
---

<html lang="es">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			.hero-image {
				width: 100%;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
			}
			.prose {
				color: rgb(var(--gray-dark));
			}
			.title {
				margin-bottom: 1.5em;
				padding: 1.5em 0;
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.title h1 {
				margin: 0;
				font-family: var(--font-sans);
				font-weight: 700;
				font-size: 2.1em;
				letter-spacing: -0.02em;
				line-height: 1.15;
			}
			.date {
				margin-bottom: 0.8em;
				font-family: var(--font-mono);
				font-size: 0.8em;
				text-transform: uppercase;
				letter-spacing: 0.06em;
				color: var(--accent);
			}
			.last-updated-on {
				font-style: italic;
				color: rgb(var(--gray));
			}
			.tags {
				margin-top: 0.8em;
				font-family: var(--font-mono);
				font-size: 0.8em;
				color: rgb(var(--gray));
			}
			.origin {
				margin-top: 0.4em;
				font-family: var(--font-mono);
				font-size: 0.8em;
				color: rgb(var(--gray));
			}
			.origin a {
				color: rgb(var(--gray-dark));
			}
			.origin a:hover {
				color: var(--accent);
				text-decoration: none;
			}
			.tldr {
				margin: 0 0 1.5em 0;
				padding: 1em 1.25em;
				border: 1px solid rgb(var(--gray-light));
				border-left: 3px solid var(--accent);
				border-radius: 6px;
				background: var(--bg-raise);
			}
			.tldr .label {
				display: block;
				margin-bottom: 0.4em;
				font-family: var(--font-mono);
				font-size: 0.75em;
				font-weight: 700;
				letter-spacing: 0.08em;
				color: var(--accent);
			}
			.tldr p {
				margin: 0;
			}
			.toc {
				margin: 0 0 2.5em 0;
				padding: 1em 1.25em;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 6px;
				font-family: var(--font-mono);
				font-size: 0.85em;
			}
			.toc .label {
				display: block;
				margin-bottom: 0.5em;
				font-size: 0.85em;
				font-weight: 700;
				letter-spacing: 0.08em;
				text-transform: uppercase;
				color: rgb(var(--gray));
			}
			.toc ol {
				margin: 0;
				padding-left: 1.4em;
			}
			.toc li {
				margin: 0.25em 0;
			}
			.toc a {
				color: rgb(var(--gray-dark));
			}
			.toc a:hover {
				color: var(--accent);
				text-decoration: none;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroImage && <Image width={1020} height={510} src={heroImage} alt="" />}
				</div>
				<div class="prose" data-pagefind-body>
					<div class="title">
						<div class="date">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<div class="last-updated-on">
										Actualizado el <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<h1>{title}</h1>
						{tags.length > 0 && <div class="tags">{tags.join(' · ')}</div>}
						{
							(issue || requestedBy) && (
								<div class="origin">
									{issue && (
										<a href={`${REPO_URL}/issues/${issue}`} target="_blank">
											#{issue}
										</a>
									)}
									{issue && requestedBy && ' · '}
									{requestedBy && (
										<>
											pedido por{' '}
											<a href={`https://github.com/${requestedBy}`} target="_blank">
												@{requestedBy}
											</a>
										</>
									)}
								</div>
							)
						}
					</div>
					{
						summary && (
							<aside class="tldr">
								<span class="label">TL;DR</span>
								<p>{summary}</p>
							</aside>
						)
					}
					{
						headings.length > 1 && (
							<nav class="toc">
								<span class="label">En este artículo</span>
								<ol>
									{headings.map((h) => (
										<li>
											<a href={`#${h.slug}`}>{h.text}</a>
										</li>
									))}
								</ol>
							</nav>
						)
					}
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
