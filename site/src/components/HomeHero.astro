---
import { REPO_URL, TOPICS_URL } from '../consts';
---

<section class="hero">
	<h1 class="typing" aria-label="Un deep dive técnico al día.">
		<span class="typing-text" aria-hidden="true">Un deep dive técnico al día.</span><span
			class="typing-cursor pending"
			aria-hidden="true">▍</span
		>
	</h1>
	<script is:inline>
		{
			const typingText = document.querySelector('.typing-text');
			const typingCursor = document.querySelector('.typing-cursor');

			if (typingText && typingCursor) {
				const characters = Array.from(typingText.textContent);
				typingText.textContent = '';
				for (const character of characters) {
					const span = document.createElement('span');
					span.textContent = character;
					span.style.visibility = 'hidden';
					typingText.appendChild(span);
				}
				[...typingText.children].forEach((span, index) => {
					window.setTimeout(() => {
						span.style.visibility = 'visible';
					}, 70 * index);
				});
				window.setTimeout(() => {
					typingCursor.classList.remove('pending');
				}, 70 * characters.length);
			}
		}
	</script>
	<div class="terminal">
		<div class="term-bar">
			<i></i><i></i><i></i>
			<span>Ctx — zsh</span>
		</div>
		<div class="term-body">
			<p class="cmd">ctx --why</p>
			<p class="out">
				Hacemos vibe coding: la IA escribe el código a una velocidad absurda. Entender qué hace
				por debajo sigue siendo nuestro trabajo — y nuestra ventaja.
			</p>
			<p class="cmd">ctx --how</p>
			<p class="out">
				Propones un tema → el equipo vota con 👍 → cada mañana (L–V) un LLM publica aquí un deep
				dive de ~15 min: desde cero hasta internals, con ejemplos de código completos.
			</p>
		</div>
	</div>
	<div class="hero-actions">
		<a class="propose" href={`${REPO_URL}/issues/new/choose`} target="_blank">proponer tema →</a>
		<a class="vote-link" href={TOPICS_URL} target="_blank">ver y votar próximos temas →</a>
	</div>
</section>

<style>
	.hero {
		padding: 2.5em 0 0 0;
	}
	.hero h1 {
		margin: 0;
		font-family: var(--font-sans);
		font-weight: 700;
		font-size: 2.6em;
		letter-spacing: -0.02em;
		line-height: 1.1;
	}
	.terminal {
		margin-top: 1.8em;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 8px;
		background: var(--bg-raise);
		overflow: hidden;
		box-shadow: var(--panel-shadow);
	}
	.term-bar {
		display: flex;
		align-items: center;
		gap: 0.45em;
		padding: 0.6em 1em;
		border-bottom: 1px solid rgb(var(--gray-light));
		font-family: var(--font-mono);
		font-size: 0.75em;
		color: rgb(var(--gray));
	}
	.term-bar i {
		width: 10px;
		height: 10px;
		border-radius: 50%;
		background: rgb(var(--gray-light));
	}
	.term-bar span {
		margin-left: 0.6em;
	}
	.term-body {
		padding: 1.25em 1.5em;
		font-family: var(--font-mono);
		font-size: 0.9em;
		line-height: 1.7;
	}
	.cmd {
		margin: 0;
		color: var(--accent);
	}
	.cmd::before {
		content: '$ ';
		color: rgb(var(--gray));
	}
	.out {
		margin: 0.2em 0 1.2em 0;
		color: rgb(var(--gray-dark));
		max-width: 40em;
	}
	.out:last-child {
		margin-bottom: 0;
	}
	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.75em 1.5em;
	}
	.propose {
		display: inline-block;
		margin-top: 1.4em;
		font-family: var(--font-mono);
		font-weight: 500;
		padding: 0.5em 1em;
		border: 1px solid var(--accent);
		border-radius: 6px;
	}
	.propose:hover {
		background: var(--accent);
		color: var(--bg);
		text-decoration: none;
	}
	.vote-link {
		margin-top: 1.4em;
		font-family: var(--font-mono);
		font-size: 0.85em;
	}
	@media (max-width: 720px) {
		.hero h1 {
			font-size: 1.9em;
		}
	}
</style>
