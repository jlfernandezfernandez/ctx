---
import { REPO_URL, SITE_TITLE } from '../consts';

const today = new Date();
---

<footer>
	<div class="footer-inner">
		<span>&copy; {today.getFullYear()} {SITE_TITLE} — generado por el equipo, para el equipo.</span>
		<div class="social-links">
			<a href={`${REPO_URL}/issues/new/choose`} target="_blank">Proponer tema</a>
			<a href={REPO_URL} target="_blank">GitHub</a>
		</div>
	</div>
</footer>
<style>
	footer {
		padding: 1.5em 1em 3em;
		border-top: 1px solid rgb(var(--gray-light));
		font-family: var(--font-mono);
		font-size: 0.8em;
		color: rgb(var(--gray));
	}
	.footer-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1em;
		max-width: 880px;
		margin: auto;
	}
	.social-links {
		display: flex;
		gap: 1em;
	}
	.social-links a {
		text-decoration: none;
		color: rgb(var(--gray));
	}
	.social-links a:hover {
		color: rgb(var(--gray-dark));
	}
	@media (max-width: 720px) {
		.footer-inner {
			display: block;
			text-align: center;
		}
		.social-links {
			justify-content: center;
		}
		.social-links {
			margin-top: 1em;
		}
	}
</style>
