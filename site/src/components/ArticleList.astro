---
import type { CollectionEntry } from 'astro:content';
import { BASE } from '../consts';
import FormattedDate from './FormattedDate.astro';
import { getReadingTime } from '../utils/reading-time';

interface Props {
	posts: CollectionEntry<'blog'>[];
}

const { posts } = Astro.props;
---

<ul class="article-list">
	{
		posts.map((post, index) => (
			<li data-read-slug={post.id}>
				<span class="index">{String(index + 1).padStart(2, '0')}</span>
				<span class="date">
					<FormattedDate date={post.data.date} /> · {getReadingTime(post.body)} min
				</span>
				<a href={`${BASE}/blog/${post.id}/`}>{post.data.title}</a>
				<span class="arrow" aria-hidden="true">→</span>
			</li>
		))
	}
</ul>
<style>
	.article-list {
		list-style: none;
		margin: 0;
		padding: 0;
	}
	li {
		display: grid;
		grid-template-columns: 2em 7.5em minmax(0, 1fr) auto;
		align-items: baseline;
		gap: 1em;
		margin: 0 -0.75em;
		padding: 0.7em 0.75em;
		border-bottom: 1px solid rgb(var(--gray-light));
		border-radius: 4px;
		transition:
			background 160ms ease,
			border-color 160ms ease;
	}
	li:hover {
		border-bottom-color: rgba(255, 180, 84, 0.35);
		background: var(--accent-soft);
	}
	.index {
		font-family: var(--font-mono);
		font-size: 0.65em;
		color: var(--accent);
		opacity: 0.7;
	}
	.date {
		font-family: var(--font-mono);
		font-size: 0.8em;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: rgb(var(--gray));
	}
	a {
		color: rgb(var(--black));
		text-decoration: none;
	}
	a:hover {
		color: var(--accent);
	}
	/* Read indicator: subtle dimmed title prefixed with a small accent check. */
	.is-read a {
		color: rgb(var(--gray));
	}
	.is-read a::before {
		content: '✓ ';
		color: var(--accent);
		opacity: 0.7;
	}
	.arrow {
		color: var(--accent);
		opacity: 0;
		transform: translateX(-0.35em);
		transition:
			opacity 160ms ease,
			transform 160ms ease;
	}
	li:hover .arrow {
		opacity: 1;
		transform: none;
	}
	@media (max-width: 720px) {
		li {
			grid-template-columns: 1.5em minmax(0, 1fr) auto;
			gap: 0.1em 0.7em;
		}
		.date {
			grid-column: 2;
			grid-row: 1;
		}
		a {
			grid-column: 2;
			grid-row: 2;
		}
		.index {
			grid-row: 1 / 3;
		}
		.arrow {
			grid-column: 3;
			grid-row: 1 / 3;
			align-self: center;
			opacity: 0.7;
			transform: none;
		}
	}
</style>
