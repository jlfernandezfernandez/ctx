---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const base = import.meta.env.BASE_URL.replace(/\/+$/, '');
const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const [latest, ...rest] = posts;
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.kicker {
				margin: 0 0 0.8em 0;
				font-family: var(--font-mono);
				font-size: 0.85em;
				color: var(--accent);
			}
			.kicker::before {
				content: '$ ';
				color: rgb(var(--gray));
			}
			.today {
				padding: 2.5em 0 2em 0;
			}
			.today h1 {
				margin: 0 0 0.3em 0;
				font-family: var(--font-sans);
				font-weight: 700;
				font-size: 2.4em;
				letter-spacing: -0.02em;
				line-height: 1.15;
			}
			.today h1 a {
				color: rgb(var(--black));
				text-decoration: none;
			}
			.today h1 a:hover {
				color: var(--accent);
			}
			.date,
			.tags {
				font-family: var(--font-mono);
				font-size: 0.8em;
				text-transform: uppercase;
				letter-spacing: 0.06em;
				color: rgb(var(--gray));
			}
			.description {
				margin: 1em 0 0 0;
				font-size: 1.1em;
				color: rgb(var(--gray-dark));
				max-width: 44em;
			}
			.read {
				display: inline-block;
				margin-top: 1.2em;
				font-family: var(--font-mono);
				font-weight: 500;
			}
			.archive {
				margin-top: 3em;
				border-top: 1px solid rgb(var(--gray-light));
				padding-top: 1.5em;
			}
			.archive h2 {
				margin: 0 0 1em 0;
				font-size: 0.85em;
				text-transform: uppercase;
				letter-spacing: 0.08em;
				color: rgb(var(--gray));
			}
			.archive ul {
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.archive li {
				display: flex;
				align-items: baseline;
				gap: 1.5em;
				padding: 0.55em 0;
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.archive .date {
				flex-shrink: 0;
				width: 7.5em;
			}
			.archive a {
				color: rgb(var(--black));
				text-decoration: none;
			}
			.archive a:hover {
				color: var(--accent);
			}
			@media (max-width: 720px) {
				.today h1 {
					font-size: 1.7em;
				}
				.archive li {
					flex-direction: column;
					gap: 0.1em;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			{
				latest && (
					<section class="today">
						<p class="kicker">cat artículo-de-hoy.md</p>
						<h1>
							<a class="cursor" href={`${base}/blog/${latest.id}/`}>
								{latest.data.title}
							</a>
						</h1>
						<p class="date">
							<FormattedDate date={latest.data.pubDate} />
							{latest.data.tags.length > 0 && <span class="tags"> · {latest.data.tags.join(' · ')}</span>}
						</p>
						<p class="description">{latest.data.description}</p>
						<a class="read" href={`${base}/blog/${latest.id}/`}>
							leer artículo →
						</a>
					</section>
				)
			}
			{
				rest.length > 0 && (
					<section class="archive">
						<h2>Anteriores</h2>
						<ul>
							{rest.map((post) => (
								<li>
									<span class="date">
										<FormattedDate date={post.data.pubDate} />
									</span>
									<a href={`${base}/blog/${post.id}/`}>{post.data.title}</a>
								</li>
							))}
						</ul>
					</section>
				)
			}
		</main>
		<Footer />
	</body>
</html>
