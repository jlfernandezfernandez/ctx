---
import { getCollection } from 'astro:content';
import ArticleList from '../components/ArticleList.astro';
import FeaturedArticle from '../components/FeaturedArticle.astro';
import HomeActivity from '../components/HomeActivity.astro';
import HomeHero from '../components/HomeHero.astro';
import ReadingStreak from '../components/ReadingStreak.astro';
import TopicQueue from '../components/TopicQueue.astro';
import Page from '../layouts/Page.astro';
import { BASE, SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const RECENT_COUNT = 4;

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
const [latest, ...rest] = posts;
const recent = rest.slice(0, RECENT_COUNT);
---

<Page title={SITE_TITLE} description={SITE_DESCRIPTION}>
	<HomeHero />
	<ReadingStreak />
	{latest && <FeaturedArticle post={latest} />}
	{
		recent.length > 0 && (
			<section class="recent">
				<h2>Anteriores</h2>
				<ArticleList posts={recent} />
			</section>
		)
	}
	{rest.length > 0 && <a class="all" href={`${BASE}/articles/`}>ver todos los artículos →</a>}
	<TopicQueue />
	<HomeActivity posts={posts} />
</Page>

<style>
	.recent {
		margin-top: 3em;
	}
	.recent h2 {
		margin: 0 0 1em 0;
		font-size: 0.85em;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: rgb(var(--gray));
	}
	.all {
		display: inline-block;
		margin-top: 1em;
		font-family: var(--font-mono);
		font-weight: 500;
	}
</style>
