---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const base = import.meta.env.BASE_URL.replace(/\/+$/, '');
const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead title={`Archivo — ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			.kicker {
				margin: 0 0 1.5em 0;
				font-family: var(--font-mono);
				font-size: 0.85em;
				color: var(--accent);
			}
			.kicker::before {
				content: '$ ';
				color: rgb(var(--gray));
			}
			ul {
				list-style: none;
				margin: 0;
				padding: 0;
			}
			li {
				display: flex;
				align-items: baseline;
				gap: 1.5em;
				padding: 0.55em 0;
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.date {
				flex-shrink: 0;
				width: 7.5em;
				font-family: var(--font-mono);
				font-size: 0.8em;
				text-transform: uppercase;
				letter-spacing: 0.06em;
				color: rgb(var(--gray));
			}
			.tags {
				margin-left: auto;
				font-family: var(--font-mono);
				font-size: 0.75em;
				color: rgb(var(--gray));
			}
			a {
				color: rgb(var(--black));
				text-decoration: none;
			}
			a:hover {
				color: var(--accent);
			}
			@media (max-width: 720px) {
				li {
					flex-direction: column;
					gap: 0.1em;
				}
				.tags {
					margin-left: 0;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<p class="kicker">ls archivo/ — {posts.length} artículo{posts.length === 1 ? '' : 's'}</p>
			<ul>
				{
					posts.map((post) => (
						<li>
							<span class="date">
								<FormattedDate date={post.data.pubDate} />
							</span>
							<a href={`${base}/blog/${post.id}/`}>{post.data.title}</a>
							{post.data.tags.length > 0 && <span class="tags">{post.data.tags.join(' · ')}</span>}
						</li>
					))
				}
			</ul>
		</main>
		<Footer />
	</body>
</html>
