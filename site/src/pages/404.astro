---
import Page from '../layouts/Page.astro';
import { BASE, SITE_TITLE } from '../consts';
---

<Page title={`${SITE_TITLE} — 404`} description="Página no encontrada.">
	<section class="lost">
		<div class="lost-bar"><i></i><i></i><i></i><span>Ctx — zsh</span></div>
		<div class="lost-body">
			<p class="kicker term-command">cat pagina-perdida.md</p>
			<h1>404<span>_</span></h1>
			<p class="error">cat: pagina-perdida.md: No such file or directory</p>
			<p>Esta página no existe — o el agente la borró sin avisar.</p>
			<a class="home" href={`${BASE}/`}>cd ~ →</a>
		</div>
	</section>
</Page>

<style>
	.lost {
		max-width: 42em;
		margin: 5vh auto 0;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 8px;
		background: var(--bg-raise);
		box-shadow: var(--panel-shadow);
		overflow: hidden;
	}
	.lost-bar {
		display: flex;
		align-items: center;
		gap: 0.4em;
		padding: 0.6em 0.9em;
		border-bottom: 1px solid rgb(var(--gray-light));
		font-family: var(--font-mono);
		font-size: 0.68em;
		color: rgb(var(--gray));
	}
	.lost-bar i {
		width: 0.65em;
		height: 0.65em;
		border-radius: 50%;
		background: rgb(var(--gray-light));
	}
	.lost-bar span {
		margin-left: 0.5em;
	}
	.lost-body {
		padding: clamp(1.5em, 6vw, 3.5em);
	}
	.lost h1 {
		font-size: clamp(3.5em, 12vw, 6.5em);
		line-height: 1;
		color: var(--accent);
	}
	.lost h1 span {
		animation: blink 1.1s steps(1) infinite;
	}
	.error {
		font-family: var(--font-mono);
		color: rgb(var(--gray-dark));
	}
	.home {
		display: inline-block;
		margin-top: 1.5em;
		font-family: var(--font-mono);
		font-weight: 500;
	}
</style>
