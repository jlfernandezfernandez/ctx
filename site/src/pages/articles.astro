---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { BASE, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const tagCounts = new Map<string, number>();
for (const post of posts) {
	for (const tag of post.data.tags) {
		tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1);
	}
}
const tags = [...tagCounts.entries()].sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]));
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead
			title={`Artículos — ${SITE_TITLE}`}
			description="Todos los deep dives publicados, filtrables por tema."
		/>
		<style>
			.kicker {
				margin: 0 0 0.8em 0;
				font-family: var(--font-mono);
				font-size: 0.85em;
				color: var(--accent);
			}
			.kicker::before {
				content: '$ ';
				color: rgb(var(--gray));
			}
			.tagcloud {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5em;
				margin: 1.5em 0 0 0;
				padding: 0;
				list-style: none;
			}
			.tagcloud a {
				display: inline-block;
				font-family: var(--font-mono);
				font-size: 0.8em;
				padding: 0.2em 0.7em;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 999px;
				color: rgb(var(--gray-dark));
			}
			.tagcloud a:hover {
				border-color: var(--accent);
				color: var(--accent);
				text-decoration: none;
			}
			.tagcloud .count {
				color: rgb(var(--gray));
			}
			.list {
				margin-top: 2em;
				list-style: none;
				padding: 0;
			}
			.list li {
				display: flex;
				align-items: baseline;
				gap: 1.5em;
				padding: 0.55em 0;
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.date {
				flex-shrink: 0;
				width: 7.5em;
				font-family: var(--font-mono);
				font-size: 0.8em;
				text-transform: uppercase;
				letter-spacing: 0.06em;
				color: rgb(var(--gray));
			}
			.list li a {
				color: rgb(var(--black));
				text-decoration: none;
			}
			.list li a:hover {
				color: var(--accent);
			}
			@media (max-width: 720px) {
				.list li {
					flex-direction: column;
					gap: 0.1em;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<p class="kicker">ls articles/</p>
			<h1>Artículos</h1>
			<p>{posts.length} deep dives publicados. Filtra por tema:</p>
			<ul class="tagcloud">
				{
					tags.map(([tag, count]) => (
						<li>
							<a href={`${BASE}/tags/${tag}/`}>
								#{tag} <span class="count">({count})</span>
							</a>
						</li>
					))
				}
			</ul>
			<ul class="list">
				{
					posts.map((post) => (
						<li>
							<span class="date">
								<FormattedDate date={post.data.pubDate} />
							</span>
							<a href={`${BASE}/blog/${post.id}/`}>{post.data.title}</a>
						</li>
					))
				}
			</ul>
		</main>
		<Footer />
	</body>
</html>
