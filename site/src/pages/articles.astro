---
import { getCollection } from 'astro:content';
import ArticleList from '../components/ArticleList.astro';
import Page from '../layouts/Page.astro';
import { BASE, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const tagCounts = new Map<string, number>();
for (const post of posts) {
	for (const tag of post.data.tags) {
		tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1);
	}
}
// Cap the cloud so it stays useful as tags accumulate; search covers the rest.
const TAG_LIMIT = 15;
const tags = [...tagCounts.entries()]
	.sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]))
	.slice(0, TAG_LIMIT);
---

<Page
	title={`${SITE_TITLE} — Artículos`}
	description="Todos los artículos publicados, filtrables por tema."
>
	<Fragment slot="head">
		<link rel="stylesheet" href={`${BASE}/pagefind/pagefind-ui.css`} />
		<script is:inline src={`${BASE}/pagefind/pagefind-ui.js`}></script>
	</Fragment>
	<p class="kicker">ls articles/</p>
	<h1>Artículos</h1>
	<p>{posts.length} artículos publicados. Busca o filtra por tema:</p>
	<div id="search"></div>
	<script is:inline>
		window.addEventListener('DOMContentLoaded', () => {
			if (typeof PagefindUI !== 'undefined') {
				new PagefindUI({
					element: '#search',
					showImages: false,
					showSubResults: true,
					translations: {
						placeholder: 'grep -r "tema" articles/',
						zero_results: 'Sin resultados para [SEARCH_TERM]',
					},
				});
			}
		});
	</script>
	<ul class="tagcloud">
		{
			tags.map(([tag, count]) => (
				<li>
					<a href={`${BASE}/tags/${tag}/`}>
						#{tag} <span class="count">({count})</span>
					</a>
				</li>
			))
		}
	</ul>
	<div class="list">
		<ArticleList posts={posts} />
	</div>
</Page>

<style>
	.tagcloud {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5em;
		margin: 1.5em 0 0 0;
		padding: 0;
		list-style: none;
	}
	.tagcloud a {
		display: inline-block;
		font-family: var(--font-mono);
		font-size: 0.8em;
		padding: 0.2em 0.7em;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 999px;
		color: rgb(var(--gray-dark));
	}
	.tagcloud a:hover {
		border-color: var(--accent);
		color: var(--accent);
		text-decoration: none;
	}
	.tagcloud .count {
		color: rgb(var(--gray));
	}
	#search {
		margin-top: 1.5em;
		--pagefind-ui-scale: 0.85;
		--pagefind-ui-primary: var(--accent);
		--pagefind-ui-text: rgb(var(--gray-dark));
		--pagefind-ui-background: var(--bg-raise);
		--pagefind-ui-border: rgb(var(--gray-light));
		--pagefind-ui-tag: rgb(var(--gray-light));
		--pagefind-ui-border-width: 1px;
		--pagefind-ui-border-radius: 6px;
		--pagefind-ui-font: var(--font-mono);
	}
	.list {
		margin-top: 2em;
	}
</style>
